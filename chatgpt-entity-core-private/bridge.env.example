# Copy this file to bridge.env and fill in your own values.
# Do not publish bridge.env if it contains private local paths.

ENTITY_CONNECTOR_HTTP_AUTH_MODE=oauth
ENTITY_CONNECTOR_HTTP_HOST=127.0.0.1
ENTITY_CONNECTOR_HTTP_PORT=3006
ENTITY_CONNECTOR_HTTP_PATH=/mcp
ENTITY_CONNECTOR_HTTP_LITE_PATH=/mcp-lite

# Public base URL, without /mcp-lite or /mcp.
ENTITY_CONNECTOR_PUBLIC_BASE_URL=https://your-machine.your-tailnet.ts.net

# Usually the same as ENTITY_CONNECTOR_PUBLIC_BASE_URL.
ENTITY_CONNECTOR_OAUTH_RESOURCE=https://your-machine.your-tailnet.ts.net

# Auth0 issuer/domain, with https:// and no trailing path.
ENTITY_CONNECTOR_OAUTH_ISSUER=https://your-tenant.us.auth0.com

# Optional. Only set if your provider requires a different audience.
# ENTITY_CONNECTOR_OAUTH_AUDIENCE=

# Optional. Defaults to the installed Psycheros data directory.
# ENTITY_CONNECTOR_DATA_DIR=C:\Users\you\AppData\Roaming\Psycheros\data\entity-core

# Start read-only for cautious testing, then set true when ready.
ENTITY_CONNECTOR_WRITE_ENABLED=false

ENTITY_CONNECTOR_CORS_ORIGINS=https://chatgpt.com,https://chat.openai.com
