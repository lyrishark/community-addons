{
  "name": "@local/codex-entity-core-connector",
  "version": "0.1.0",
  "exports": "./src/server.ts",
  "nodeModulesDir": "none",
  "imports": {
    "@db/sqlite": "jsr:@db/sqlite@^0.12",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/path": "jsr:@std/path@^1",
    "express": "npm:express@^5",
    "jose": "npm:jose@^6",
    "zod": "npm:zod@^3"
  },
  "tasks": {
    "start": "deno run --node-modules-dir=none -A src/server.ts",
    "start:stdio": "deno run --node-modules-dir=none -A src/server.ts",
    "start:http": "deno run --node-modules-dir=none -A src/http.ts",
    "check": "deno check src/auth.ts src/core.ts src/server.ts src/http.ts scripts/smoke.ts scripts/http-smoke.ts scripts/oauth-smoke.ts",
    "smoke": "deno run --node-modules-dir=none -A scripts/smoke.ts",
    "smoke:http": "deno run --node-modules-dir=none -A scripts/http-smoke.ts",
    "smoke:oauth": "deno run --node-modules-dir=none -A scripts/oauth-smoke.ts",
    "fmt": "deno fmt"
  },
  "compilerOptions": {
    "strict": true
  }
}
